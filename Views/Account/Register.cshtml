@model RegisterDto
@{
    ViewData["Title"] = "Crear cuenta";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<main class="flex-1 flex flex-col items-center justify-center px-margin-mobile py-10 min-h-[80vh]">
    <div class="mb-8 text-center">
        <div class="flex items-center justify-center mb-4">
            <div class="w-12 h-12 bg-primary flex items-center justify-center rounded-xl shadow-lg">
                <span class="material-symbols-outlined text-on-primary text-3xl">travel_explore</span>
            </div>
        </div>
        <h1 class="font-display text-headline-md text-primary font-bold">Cosmos Stay</h1>
    </div>

    <div class="w-full max-w-md bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant p-8">
        <h2 class="font-display text-title-lg text-on-background mb-6">Crear cuenta</h2>

        <form asp-action="Register" asp-route-returnUrl="@returnUrl" method="post" class="space-y-4">
            <div asp-validation-summary="ModelOnly" class="text-error text-label-md bg-error-container/30 rounded-lg p-3 [&:empty]:hidden"></div>

            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-1">
                    <label asp-for="FirstName" class="font-semibold text-primary block">Nombres</label>
                    <input asp-for="FirstName" placeholder="Ana" class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface-container-low text-body-md focus:ring-2 ring-secondary" />
                    <span asp-validation-for="FirstName" class="text-error text-label-md"></span>
                </div>
                <div class="space-y-1">
                    <label asp-for="LastName" class="font-semibold text-primary block">Apellidos</label>
                    <input asp-for="LastName" placeholder="García" class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface-container-low text-body-md focus:ring-2 ring-secondary" />
                    <span asp-validation-for="LastName" class="text-error text-label-md"></span>
                </div>
            </div>

            <div class="space-y-1">
                <label asp-for="Email" class="font-semibold text-primary block">Correo</label>
                <input asp-for="Email" placeholder="tucorreo@ejemplo.com" type="email" class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface-container-low text-body-md focus:ring-2 ring-secondary" />
                <span asp-validation-for="Email" class="text-error text-label-md"></span>
            </div>

            <div class="space-y-1">
                <label asp-for="Password" class="font-semibold text-primary block">Contraseña</label>
                <input asp-for="Password" placeholder="Mínimo 8 caracteres" type="password" class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface-container-low text-body-md focus:ring-2 ring-secondary" />
                <span asp-validation-for="Password" class="text-error text-label-md"></span>
            </div>

            <div class="space-y-1">
                <label class="font-semibold text-primary block">Quiero registrarme como</label>
                <select asp-for="Role" class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface-container-low text-body-md focus:ring-2 ring-secondary">
                    <option value="Guest">Huésped (quiero reservar)</option>
                    <option value="Owner">Propietario (quiero publicar)</option>
                </select>
            </div>

            <button type="submit" class="w-full h-12 bg-primary text-on-primary font-semibold rounded-lg hover:opacity-90 active:scale-[0.98] transition-all shadow-sm flex items-center justify-center gap-2">
                Crear cuenta <span class="material-symbols-outlined text-[18px]">person_add</span>
            </button>
        </form>

        <p class="text-center mt-8 text-body-md text-on-surface-variant">
            ¿Ya tienes cuenta?
            <a class="text-secondary font-semibold hover:underline" asp-action="Login" asp-route-returnUrl="@returnUrl">Inicia sesión</a>
        </p>
    </div>
</main>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
