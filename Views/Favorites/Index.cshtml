@model IReadOnlyList<PropertyListItemDto>
@{
    ViewData["Title"] = "Mis favoritos";
}

<section class="px-margin-mobile py-8 max-w-container-max mx-auto">
    <h1 class="font-display text-headline-md text-primary mb-6">Mis favoritos</h1>

    @if (Model.Count == 0)
    {
        <div class="bg-surface-container rounded-2xl p-10 text-center text-on-surface-variant">
            <span class="material-symbols-outlined text-5xl text-primary/40">favorite</span>
            <p class="mt-3">Tu wishlist está vacía.</p>
            <a href="/Catalog" class="inline-block mt-4 text-secondary font-semibold">Explorar propiedades</a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            @foreach (var p in Model)
            {
                <div class="relative">
                    <partial name="_PropertyCard" model="p" />
                    <form asp-action="Remove" asp-route-propertyId="@p.Id" asp-route-returnUrl="/Favorites" method="post"
                          class="absolute top-3 right-3">
                        <button type="submit" title="Quitar de favoritos"
                                class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 shadow-sm active:scale-90 transition-transform">
                            <span class="material-symbols-outlined text-error" style="font-variation-settings:'FILL' 1;">favorite</span>
                        </button>
                    </form>
                </div>
            }
        </div>
    }
</section>
