@model IReadOnlyList<NotificationDto>
@{
    ViewData["Title"] = "Notificaciones";
    string Icon(string type) => type switch
    {
        "BookingConfirmed" => "event_available",
        "BookingCancelled" => "event_busy",
        "KycApproved" => "verified",
        "KycRejected" => "gpp_bad",
        "CheckInReminder" => "login",
        "CheckOutReminder" => "logout",
        _ => "notifications"
    };
}

<section class="px-margin-mobile py-8 max-w-md mx-auto">
    <div class="flex items-center justify-between mb-6">
        <h1 class="font-display text-headline-md text-primary">Notificaciones</h1>
        @if (Model.Any(n => !n.IsRead))
        {
            <form asp-action="MarkAllRead" method="post">
                <button type="submit" class="text-secondary font-semibold text-label-md">Marcar todas</button>
            </form>
        }
    </div>

    @if (Model.Count == 0)
    {
        <div class="bg-surface-container rounded-2xl p-10 text-center text-on-surface-variant">
            <span class="material-symbols-outlined text-5xl text-primary/40">notifications_off</span>
            <p class="mt-3">No tienes notificaciones.</p>
        </div>
    }
    else
    {
        <div class="space-y-3">
            @foreach (var n in Model)
            {
                <div class="p-4 rounded-xl flex items-start gap-4 border @(n.IsRead ? "bg-surface-container-low border-outline-variant" : "bg-surface-container-high border-primary-container")">
                    <div class="w-10 h-10 rounded-lg bg-surface-container-highest flex items-center justify-center shrink-0 text-primary">
                        <span class="material-symbols-outlined">@Icon(n.Type)</span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2">
                            <h3 class="font-semibold text-on-background">@n.Title</h3>
                            @if (!n.IsRead)
                            {
                                <span class="w-2 h-2 bg-secondary rounded-full"></span>
                            }
                        </div>
                        <p class="text-body-md text-on-surface-variant">@n.Message</p>
                        <p class="text-label-md text-outline mt-1">@n.CreatedAt.ToString("yyyy-MM-dd HH:mm")</p>
                    </div>
                    @if (!n.IsRead)
                    {
                        <form asp-action="MarkRead" asp-route-id="@n.Id" method="post">
                            <button type="submit" title="Marcar como leída" class="text-on-surface-variant">
                                <span class="material-symbols-outlined">done</span>
                            </button>
                        </form>
                    }
                </div>
            }
        </div>
    }
</section>
