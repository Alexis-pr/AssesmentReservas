@model PropertyDetailDto
@{
    ViewData["Title"] = Model.Title;
    var isAuth = User.Identity?.IsAuthenticated ?? false;
    var isFav = (bool)(ViewBag.IsFavorite ?? false);
    var returnUrl = $"/Catalog/Details/{Model.Id}";
}

<!-- Favorito (flota sobre la galería) -->
<div class="relative max-w-container-max mx-auto">
    <div class="absolute top-4 right-4 z-20">
        @if (!isAuth)
        {
            <a href="/Account/Login?returnUrl=@returnUrl" title="Inicia sesión para guardar"
               class="w-10 h-10 flex items-center justify-center rounded-full bg-white/90 shadow-lg text-on-surface">
                <span class="material-symbols-outlined">favorite</span>
            </a>
        }
        else
        {
            <form asp-controller="Favorites" asp-action="@(isFav ? "Remove" : "Add")" asp-route-propertyId="@Model.Id" asp-route-returnUrl="@returnUrl" method="post">
                <button type="submit" class="w-10 h-10 flex items-center justify-center rounded-full bg-white/90 shadow-lg active:scale-90 transition-transform">
                    <span class="material-symbols-outlined @(isFav ? "text-error" : "text-on-surface")" style="@(isFav ? "font-variation-settings:'FILL' 1;" : "")">favorite</span>
                </button>
            </form>
        }
    </div>
</div>

<main class="pb-32 max-w-container-max mx-auto">
    <!-- Galería -->
    <section class="relative w-full aspect-[4/3] md:aspect-[21/9] overflow-hidden bg-surface-container">
        @if (Model.Images.Count > 0)
        {
            <div class="flex h-full overflow-x-auto snap-x snap-mandatory hide-scrollbar">
                @foreach (var img in Model.Images)
                {
                    <div class="min-w-full h-full snap-start">
                        <img class="w-full h-full object-cover" src="@img.Url" alt="@Model.Title" />
                    </div>
                }
            </div>
        }
        else
        {
            <div class="w-full h-full flex items-center justify-center text-primary/30">
                <span class="material-symbols-outlined text-7xl">apartment</span>
            </div>
        }
    </section>

    <div class="px-margin-mobile mt-6">
        <!-- Encabezado -->
        <div class="space-y-1">
            <h1 class="font-display text-headline-lg-mobile text-primary font-bold tracking-tight">@Model.Title</h1>
            <div class="flex items-center gap-1 text-on-surface-variant">
                <span class="material-symbols-outlined text-[18px]">location_on</span>
                <span class="text-body-md">@Model.City, @Model.Country</span>
            </div>
        </div>

        <!-- Specs -->
        <div class="flex gap-4 py-6 border-b border-outline-variant overflow-x-auto hide-scrollbar">
            <div class="flex flex-col items-center min-w-[80px] bg-surface-container-low p-3 rounded-xl">
                <span class="material-symbols-outlined text-primary mb-1">group</span>
                <span class="text-label-md text-on-surface">@Model.MaxGuests huéspedes</span>
            </div>
            <div class="flex flex-col items-center min-w-[80px] bg-surface-container-low p-3 rounded-xl">
                <span class="material-symbols-outlined text-primary mb-1">bed</span>
                <span class="text-label-md text-on-surface">@Model.Bedrooms hab.</span>
            </div>
            <div class="flex flex-col items-center min-w-[80px] bg-surface-container-low p-3 rounded-xl">
                <span class="material-symbols-outlined text-primary mb-1">bathtub</span>
                <span class="text-label-md text-on-surface">@Model.Bathrooms baños</span>
            </div>
        </div>

        <!-- Descripción -->
        <div class="py-6">
            <h2 class="font-title-lg text-on-surface mb-3">Sobre este espacio</h2>
            <p class="text-body-md text-on-surface-variant leading-relaxed whitespace-pre-line">@Model.Description</p>
        </div>

        <!-- Política de horarios -->
        <div class="py-6 border-t border-outline-variant flex flex-col gap-4">
            <div class="flex items-start gap-4">
                <div class="w-10 h-10 flex items-center justify-center bg-secondary-container/10 text-secondary rounded-lg shrink-0">
                    <span class="material-symbols-outlined">login</span>
                </div>
                <div><h3 class="font-title-lg text-on-surface">Check-in</h3><p class="text-on-surface-variant">Después de las 2:00 PM</p></div>
            </div>
            <div class="flex items-start gap-4">
                <div class="w-10 h-10 flex items-center justify-center bg-error-container/20 text-error rounded-lg shrink-0">
                    <span class="material-symbols-outlined">logout</span>
                </div>
                <div><h3 class="font-title-lg text-on-surface">Check-out</h3><p class="text-on-surface-variant">Antes de las 12:00 PM</p></div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.AddressLine))
        {
            <div class="py-6 border-t border-outline-variant">
                <h2 class="font-title-lg text-on-surface mb-2">Dónde estarás</h2>
                <p class="text-on-surface-variant text-body-md flex items-center gap-2">
                    <span class="material-symbols-outlined">domain</span>@Model.AddressLine
                </p>
            </div>
        }
    </div>
</main>

<!-- Barra de reserva fija -->
<div class="fixed bottom-16 left-0 w-full bg-surface-container-lowest border-t border-outline-variant px-margin-mobile py-3 z-40 shadow-[0_-8px_30px_rgb(0,0,0,0.06)]">
    <div class="max-w-container-max mx-auto flex items-center justify-between gap-4">
        <div class="flex flex-col">
            <div class="flex items-baseline gap-1">
                <span class="text-headline-md font-bold text-primary">@Model.PricePerNight.Cop()</span>
                <span class="text-on-surface-variant text-body-md">/ noche</span>
            </div>
        </div>
        @if (!isAuth)
        {
            <a href="/Account/Login?returnUrl=/Catalog/Details/@Model.Id"
               class="bg-primary text-white px-8 h-12 rounded-xl font-title-lg shadow-lg active:scale-95 transition-all flex items-center">
                Inicia sesión para reservar
            </a>
        }
        else
        {
            <a href="/Bookings/Create?propertyId=@Model.Id"
               class="bg-primary text-white px-10 h-12 rounded-xl font-title-lg shadow-lg active:scale-95 transition-all flex items-center">
                Reservar
            </a>
        }
    </div>
</div>
