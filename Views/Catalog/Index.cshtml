@model PagedResult<PropertyListItemDto>
@{
    ViewData["Title"] = "Explorar";
    var f = ViewBag.Filter as PropertySearchDto ?? new PropertySearchDto();
}

<!-- Filtros -->
<div class="sticky top-16 z-40 bg-surface/95 backdrop-blur-md py-4 px-margin-mobile border-b border-outline-variant">
    <form method="get" action="/Catalog" class="max-w-container-max mx-auto grid grid-cols-2 md:grid-cols-5 gap-3">
        <div class="col-span-2 md:col-span-1 flex items-center bg-surface-container-low rounded-full border border-outline-variant px-4 py-2">
            <span class="material-symbols-outlined text-primary text-lg mr-2">search</span>
            <input name="city" value="@f.City" placeholder="Ciudad" class="bg-transparent border-none focus:ring-0 text-label-md w-full p-0" />
        </div>
        <input name="checkIn" type="date" value="@(f.CheckIn?.ToString("yyyy-MM-dd"))" class="bg-surface-container-low rounded-full border border-outline-variant px-4 py-2 text-label-md focus:ring-0" />
        <input name="checkOut" type="date" value="@(f.CheckOut?.ToString("yyyy-MM-dd"))" class="bg-surface-container-low rounded-full border border-outline-variant px-4 py-2 text-label-md focus:ring-0" />
        <input name="minGuests" type="number" min="1" value="@f.MinGuests" placeholder="Huéspedes" class="bg-surface-container-low rounded-full border border-outline-variant px-4 py-2 text-label-md focus:ring-0" />
        <button type="submit" class="bg-primary text-white rounded-full px-4 py-2 font-label-md active:scale-95 transition-transform">Buscar</button>
    </form>
</div>

<section class="px-margin-mobile mt-6 max-w-container-max mx-auto">
    <p class="text-on-surface-variant text-label-md mb-4">@Model.Total resultado(s)</p>

    @if (Model.Items.Count == 0)
    {
        <div class="bg-surface-container rounded-2xl p-10 text-center text-on-surface-variant">
            <span class="material-symbols-outlined text-5xl text-primary/40">travel_explore</span>
            <p class="mt-3">No se encontraron propiedades con esos filtros.</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            @foreach (var p in Model.Items)
            {
                <article class="group">
                    <a href="/Catalog/Details/@p.Id">
                        <div class="relative aspect-[16/10] w-full rounded-2xl overflow-hidden shadow-sm mb-4 bg-surface-container">
                            @if (!string.IsNullOrEmpty(p.CoverImageUrl))
                            {
                                <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="@p.CoverImageUrl" alt="@p.Title" />
                            }
                            else
                            {
                                <div class="w-full h-full flex items-center justify-center text-primary/40"><span class="material-symbols-outlined text-5xl">apartment</span></div>
                            }
                            <div class="absolute bottom-4 left-4 px-3 py-1 bg-primary text-on-primary rounded-full font-label-md text-label-md">Disponible</div>
                        </div>
                        <div class="flex justify-between items-start">
                            <div>
                                <h3 class="font-title-lg text-on-background">@p.Title</h3>
                                <p class="text-body-md text-on-surface-variant flex items-center gap-1">
                                    <span class="material-symbols-outlined text-sm">location_on</span>@p.City, @p.Country
                                </p>
                                <p class="text-label-md text-outline mt-1">Hasta @p.MaxGuests huéspedes</p>
                            </div>
                            <div class="text-right">
                                <p class="font-display text-title-lg font-bold text-primary">@p.PricePerNight.Cop()</p>
                                <p class="text-label-md text-on-surface-variant">por noche</p>
                            </div>
                        </div>
                    </a>
                </article>
            }
        </div>
    }
</section>
