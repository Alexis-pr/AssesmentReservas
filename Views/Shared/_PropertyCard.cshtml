@model PropertyListItemDto
<a href="/Catalog/Details/@Model.Id" class="block min-w-[280px] bg-surface-container-lowest rounded-xl overflow-hidden border border-outline-variant shadow-sm transition-transform active:scale-95">
    <div class="relative h-48 bg-surface-container">
        @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
        {
            <img class="w-full h-full object-cover" src="@Model.CoverImageUrl" alt="@Model.Title" />
        }
        else
        {
            <div class="w-full h-full flex items-center justify-center text-primary/40">
                <span class="material-symbols-outlined text-5xl">apartment</span>
            </div>
        }
    </div>
    <div class="p-4">
        <h3 class="font-title-lg text-on-background truncate">@Model.Title</h3>
        <p class="text-on-surface-variant text-body-md mb-3 flex items-center gap-1">
            <span class="material-symbols-outlined text-sm">location_on</span>
            @Model.City, @Model.Country
        </p>
        <div class="flex items-baseline gap-1">
            <span class="text-primary font-bold text-lg">@Model.PricePerNight.Cop()</span>
            <span class="text-on-surface-variant text-label-md">/ noche</span>
        </div>
    </div>
</a>
