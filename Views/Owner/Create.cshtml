@model PropertyCreateDto
@{
    ViewData["Title"] = "Publicar inmueble";
}

<section class="px-margin-mobile py-8 max-w-md mx-auto">
    <h1 class="font-display text-headline-md text-primary mb-6">Publicar inmueble</h1>

    <form asp-action="Create" method="post" class="space-y-4">
        <div asp-validation-summary="All" class="text-error text-label-md bg-error-container/30 rounded-lg p-3 [&:empty]:hidden"></div>

        <div class="space-y-1">
            <label asp-for="Title" class="font-semibold text-primary block">Título</label>
            <input asp-for="Title" class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface-container-low focus:ring-2 ring-secondary" />
            <span asp-validation-for="Title" class="text-error text-label-md"></span>
        </div>

        <div class="space-y-1">
            <label asp-for="Description" class="font-semibold text-primary block">Descripción</label>
            <textarea asp-for="Description" rows="4" class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface-container-low focus:ring-2 ring-secondary"></textarea>
            <span asp-validation-for="Description" class="text-error text-label-md"></span>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div class="space-y-1">
                <label asp-for="City" class="font-semibold text-primary block">Ciudad</label>
                <input asp-for="City" class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface-container-low focus:ring-2 ring-secondary" />
                <span asp-validation-for="City" class="text-error text-label-md"></span>
            </div>
            <div class="space-y-1">
                <label asp-for="Country" class="font-semibold text-primary block">País</label>
                <input asp-for="Country" class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface-container-low focus:ring-2 ring-secondary" />
                <span asp-validation-for="Country" class="text-error text-label-md"></span>
            </div>
        </div>

        <div class="space-y-1">
            <label asp-for="AddressLine" class="font-semibold text-primary block">Dirección</label>
            <input asp-for="AddressLine" class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface-container-low focus:ring-2 ring-secondary" />
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div class="space-y-1">
                <label asp-for="PricePerNight" class="font-semibold text-primary block">Precio/noche</label>
                <input asp-for="PricePerNight" type="number" step="0.01" class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface-container-low focus:ring-2 ring-secondary" />
                <span asp-validation-for="PricePerNight" class="text-error text-label-md"></span>
            </div>
            <div class="space-y-1">
                <label asp-for="MaxGuests" class="font-semibold text-primary block">Huéspedes máx.</label>
                <input asp-for="MaxGuests" type="number" class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface-container-low focus:ring-2 ring-secondary" />
                <span asp-validation-for="MaxGuests" class="text-error text-label-md"></span>
            </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div class="space-y-1">
                <label asp-for="Bedrooms" class="font-semibold text-primary block">Habitaciones</label>
                <input asp-for="Bedrooms" type="number" class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface-container-low focus:ring-2 ring-secondary" />
            </div>
            <div class="space-y-1">
                <label asp-for="Bathrooms" class="font-semibold text-primary block">Baños</label>
                <input asp-for="Bathrooms" type="number" class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface-container-low focus:ring-2 ring-secondary" />
            </div>
        </div>

        <button type="submit" class="w-full h-12 bg-primary text-on-primary rounded-xl font-semibold shadow-lg active:scale-95 transition-transform">
            Publicar inmueble
        </button>
        <p class="text-label-md text-on-surface-variant text-center">Podrás subir fotos en el siguiente paso.</p>
    </form>
</section>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
