@model PropertyDetailDto
@{
    ViewData["Title"] = "Gestionar inmueble";
}

<section class="px-margin-mobile py-8 max-w-md mx-auto">
    <a href="/Owner/Properties" class="text-secondary text-label-md font-semibold flex items-center gap-1 mb-4">
        <span class="material-symbols-outlined text-[18px]">arrow_back</span> Mis inmuebles
    </a>

    <h1 class="font-display text-headline-md text-primary mb-1">@Model.Title</h1>
    <p class="text-on-surface-variant mb-6">@Model.City, @Model.Country · @Model.PricePerNight.Cop() / noche</p>

    @if (TempData["Success"] != null)
    {
        <div class="bg-primary-container/30 text-primary rounded-lg p-3 mb-4 text-body-md">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="bg-error-container/40 text-error rounded-lg p-3 mb-4 text-body-md">@TempData["Error"]</div>
    }

    <!-- Galería actual -->
    <h2 class="font-title-lg text-on-surface mb-3">Fotos</h2>
    @if (Model.Images.Count == 0)
    {
        <p class="text-on-surface-variant text-body-md mb-4">Aún no hay fotos.</p>
    }
    else
    {
        <div class="grid grid-cols-3 gap-2 mb-4">
            @foreach (var img in Model.Images)
            {
                <div class="relative aspect-square rounded-lg overflow-hidden border border-outline-variant">
                    <img class="w-full h-full object-cover" src="@img.Url" alt="foto" />
                    @if (img.IsCover)
                    {
                        <span class="absolute bottom-1 left-1 bg-primary text-white text-[10px] px-1.5 rounded">Portada</span>
                    }
                </div>
            }
        </div>
    }

    <!-- Subir imagen -->
    <form asp-action="UploadImage" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="bg-surface-container-low p-4 rounded-xl space-y-3 mb-8">
        <label class="block">
            <span class="font-semibold text-primary text-body-md">Subir nueva foto</span>
            <input type="file" name="file" accept="image/*" required class="mt-2 block w-full text-body-md" />
        </label>
        <label class="flex items-center gap-2 text-body-md">
            <input type="checkbox" name="isCover" value="true" class="rounded border-outline-variant" /> Usar como portada
        </label>
        <button type="submit" class="w-full h-11 bg-primary text-on-primary rounded-lg font-semibold flex items-center justify-center gap-2">
            <span class="material-symbols-outlined text-[18px]">cloud_upload</span> Subir
        </button>
    </form>

    <!-- Desactivar -->
    <form asp-action="Deactivate" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('¿Desactivar este inmueble? Dejará de aparecer en el catálogo.');">
        <button type="submit" class="w-full h-11 border border-error text-error rounded-lg font-semibold flex items-center justify-center gap-2">
            <span class="material-symbols-outlined text-[18px]">visibility_off</span> Desactivar inmueble
        </button>
    </form>
</section>
