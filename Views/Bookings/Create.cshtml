@model BookingCreateViewModel
@{
    ViewData["Title"] = "Reservar";
}

<main class="px-margin-mobile py-8 max-w-md mx-auto w-full">
    <h2 class="font-display text-headline-lg-mobile text-on-surface mb-6">Tu estancia</h2>

    <!-- Resumen del inmueble -->
    <div class="rounded-2xl overflow-hidden shadow-sm aspect-video mb-3 relative bg-surface-container">
        @if (Model.Property.Images.Count > 0)
        {
            <img class="w-full h-full object-cover" src="@Model.Property.Images[0].Url" alt="@Model.Property.Title" />
        }
        else
        {
            <div class="w-full h-full flex items-center justify-center text-primary/30"><span class="material-symbols-outlined text-5xl">apartment</span></div>
        }
    </div>
    <h3 class="font-title-lg text-on-surface">@Model.Property.Title</h3>
    <p class="text-body-md text-on-surface-variant mb-6">@Model.Property.City, @Model.Property.Country</p>

    @if (!Model.IsKycVerified)
    {
        <div class="bg-error-container/40 border border-error/30 rounded-xl p-5 flex items-start gap-3">
            <span class="material-symbols-outlined text-error mt-0.5">gpp_maybe</span>
            <div>
                <h4 class="font-semibold text-on-surface">Validación de identidad requerida</h4>
                <p class="text-body-md text-on-surface-variant mb-3">Debes validar tu identidad (KYC) antes de tu primera reserva.</p>
                <a href="/Kyc" class="inline-flex items-center gap-1 bg-primary text-white px-4 py-2 rounded-lg font-semibold text-label-md">
                    <span class="material-symbols-outlined text-[18px]">verified_user</span> Validar identidad
                </a>
            </div>
        </div>
    }
    else
    {
        <form asp-action="Create" method="post" class="space-y-4"
              data-price="@Model.Property.PricePerNight">
            <div asp-validation-summary="All" class="text-error text-label-md bg-error-container/30 rounded-lg p-3 [&:empty]:hidden"></div>
            <input type="hidden" asp-for="Form.PropertyId" />

            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-1">
                    <label asp-for="Form.CheckInDate" class="font-semibold text-primary block">Check-in</label>
                    <input asp-for="Form.CheckInDate" type="date" id="checkIn"
                           class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface-container-low text-body-md focus:ring-2 ring-secondary" />
                </div>
                <div class="space-y-1">
                    <label asp-for="Form.CheckOutDate" class="font-semibold text-primary block">Check-out</label>
                    <input asp-for="Form.CheckOutDate" type="date" id="checkOut"
                           class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface-container-low text-body-md focus:ring-2 ring-secondary" />
                </div>
            </div>

            <p class="text-label-md text-on-surface-variant flex items-center gap-1">
                <span class="material-symbols-outlined text-[16px]">schedule</span>
                Check-in 2:00 PM · Check-out 12:00 PM
            </p>

            <!-- Total en vivo -->
            <div class="bg-surface-container-lowest border border-outline-variant rounded-2xl p-6 shadow-sm">
                <div class="flex justify-between items-center mb-2">
                    <span class="text-body-lg text-on-surface-variant">@Model.Property.PricePerNight.Cop() × <span id="nights">0</span> noches</span>
                    <span class="text-body-lg font-semibold text-on-surface" id="subtotal">@(0m.Cop())</span>
                </div>
                <hr class="border-outline-variant my-3" />
                <div class="flex justify-between items-center">
                    <span class="text-title-lg text-on-surface">Total</span>
                    <span class="text-title-lg text-primary" id="total">@(0m.Cop())</span>
                </div>
            </div>

            <button type="submit" class="w-full h-14 bg-primary text-on-primary rounded-full font-bold text-lg shadow-lg active:scale-95 transition-all flex items-center justify-center gap-2">
                Confirmar reserva <span class="material-symbols-outlined">check_circle</span>
            </button>
        </form>
    }
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const form = document.querySelector('form[data-price]');
        if (form) {
            const price = parseFloat(form.dataset.price) || 0;
            const ci = document.getElementById('checkIn');
            const co = document.getElementById('checkOut');
            const fmt = n => new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(n);
            function recalc() {
                const a = new Date(ci.value), b = new Date(co.value);
                let nights = 0;
                if (ci.value && co.value && b > a) nights = Math.round((b - a) / 86400000);
                document.getElementById('nights').innerText = nights;
                document.getElementById('subtotal').innerText = fmt(nights * price);
                document.getElementById('total').innerText = fmt(nights * price);
            }
            ci.addEventListener('change', recalc);
            co.addEventListener('change', recalc);
        }
    </script>
}
