@model AuthUserDto
@{
    ViewData["Title"] = "Mi perfil";
}

<section class="px-margin-mobile py-8 max-w-md mx-auto">
    <div class="flex flex-col items-center text-center mb-8">
        <div class="w-20 h-20 rounded-full bg-primary-fixed-dim flex items-center justify-center text-primary mb-3">
            <span class="material-symbols-outlined text-5xl">person</span>
        </div>
        <h1 class="font-display text-headline-md text-primary">@Model.FirstName @Model.LastName</h1>
        <p class="text-on-surface-variant">@Model.Email</p>
        <div class="flex gap-2 mt-2">
            @foreach (var role in Model.Roles)
            {
                <span class="px-3 py-1 bg-secondary-container/30 text-secondary rounded-full text-label-md">@role</span>
            }
        </div>
    </div>

    <div class="bg-surface-container-lowest rounded-xl border border-outline-variant divide-y divide-outline-variant">
        <div class="flex items-center justify-between p-4">
            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary">verified_user</span>
                <span>Validación de identidad</span>
            </div>
            @if (Model.IsKycVerified)
            {
                <span class="text-secondary font-semibold text-label-md flex items-center gap-1"><span class="material-symbols-outlined text-base">check_circle</span> Verificado</span>
            }
            else
            {
                <a href="/Kyc" class="text-secondary font-semibold text-label-md hover:underline">Validar ahora</a>
            }
        </div>
        <a href="/Bookings" class="flex items-center justify-between p-4">
            <div class="flex items-center gap-3"><span class="material-symbols-outlined text-primary">luggage</span><span>Mis reservas</span></div>
            <span class="material-symbols-outlined text-on-surface-variant">chevron_right</span>
        </a>
        <a href="/Favorites" class="flex items-center justify-between p-4">
            <div class="flex items-center gap-3"><span class="material-symbols-outlined text-primary">favorite</span><span>Mis favoritos</span></div>
            <span class="material-symbols-outlined text-on-surface-variant">chevron_right</span>
        </a>
    </div>

    <form asp-action="Logout" method="post" class="mt-8">
        <button type="submit" class="w-full h-12 border border-error text-error font-semibold rounded-lg hover:bg-error-container/20 transition-colors flex items-center justify-center gap-2">
            <span class="material-symbols-outlined text-[18px]">logout</span> Cerrar sesión
        </button>
    </form>
</section>
