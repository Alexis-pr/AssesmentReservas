@model DashboardDto
@{
    ViewData["Title"] = "Panel propietario";
}

<main class="px-margin-mobile py-8 max-w-container-max mx-auto">
    <section class="mb-6 flex flex-wrap items-end justify-between gap-4">
        <div>
            <p class="text-on-surface-variant">Panel del propietario</p>
            <h2 class="font-display text-headline-lg-mobile text-on-background">Resumen del portafolio</h2>
        </div>
        <div class="flex gap-2">
            <a href="/Owner/Properties" class="px-4 py-2 rounded-lg border border-outline-variant text-primary font-semibold text-label-md flex items-center gap-1">
                <span class="material-symbols-outlined text-[18px]">apartment</span> Inmuebles
            </a>
            <a href="/Owner/ReportExcel?from=@Model.From.ToString("yyyy-MM-dd")&to=@Model.To.ToString("yyyy-MM-dd")"
               class="px-4 py-2 rounded-lg bg-primary text-white font-semibold text-label-md flex items-center gap-1">
                <span class="material-symbols-outlined text-[18px]">download</span> Excel
            </a>
        </div>
    </section>

    <!-- Rango de fechas -->
    <form method="get" class="flex flex-wrap items-end gap-3 mb-6 bg-surface-container-low p-4 rounded-xl">
        <div><label class="block text-label-md text-primary mb-1">Desde</label>
            <input type="date" name="from" value="@Model.From.ToString("yyyy-MM-dd")" class="rounded-lg border border-outline-variant bg-surface-container-lowest px-3 py-2 text-body-md" /></div>
        <div><label class="block text-label-md text-primary mb-1">Hasta</label>
            <input type="date" name="to" value="@Model.To.ToString("yyyy-MM-dd")" class="rounded-lg border border-outline-variant bg-surface-container-lowest px-3 py-2 text-body-md" /></div>
        <button type="submit" class="px-4 py-2 rounded-lg bg-primary text-white font-semibold text-label-md">Aplicar</button>
    </form>

    <!-- KPIs -->
    <section class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-surface-container-lowest p-4 rounded-xl shadow-sm border border-outline-variant">
            <span class="material-symbols-outlined text-secondary" style="font-variation-settings:'FILL' 1;">payments</span>
            <p class="text-label-md text-on-surface-variant uppercase mt-2">Ingresos</p>
            <p class="font-display text-title-lg text-on-background">@Model.TotalRevenue.Cop()</p>
        </div>
        <div class="bg-surface-container-lowest p-4 rounded-xl shadow-sm border border-outline-variant">
            <span class="material-symbols-outlined text-secondary" style="font-variation-settings:'FILL' 1;">analytics</span>
            <p class="text-label-md text-on-surface-variant uppercase mt-2">Ocupación</p>
            <p class="font-display text-title-lg text-on-background">@Model.OccupancyRate.ToString("P0")</p>
        </div>
        <div class="bg-surface-container-lowest p-4 rounded-xl shadow-sm border border-outline-variant">
            <span class="material-symbols-outlined text-secondary" style="font-variation-settings:'FILL' 1;">calendar_today</span>
            <p class="text-label-md text-on-surface-variant uppercase mt-2">Reservas</p>
            <p class="font-display text-title-lg text-on-background">@Model.TotalBookings</p>
        </div>
        <div class="bg-surface-container-lowest p-4 rounded-xl shadow-sm border border-outline-variant">
            <span class="material-symbols-outlined text-secondary" style="font-variation-settings:'FILL' 1;">apartment</span>
            <p class="text-label-md text-on-surface-variant uppercase mt-2">Inmuebles</p>
            <p class="font-display text-title-lg text-on-background">@Model.PropertiesCount</p>
        </div>
    </section>

    <!-- Métricas por inmueble -->
    <section class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant overflow-hidden">
        <h3 class="font-display text-title-lg text-on-background p-5 pb-3">Rendimiento por inmueble</h3>
        @if (Model.Properties.Count == 0)
        {
            <p class="px-5 pb-5 text-on-surface-variant">Aún no hay inmuebles. <a href="/Owner/Create" class="text-secondary font-semibold">Publicar uno</a>.</p>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full text-body-md">
                    <thead class="text-label-md text-on-surface-variant uppercase bg-surface-container-low">
                        <tr>
                            <th class="text-left p-3">Inmueble</th>
                            <th class="text-right p-3">Reservas</th>
                            <th class="text-right p-3">Noches</th>
                            <th class="text-right p-3">Ocupación</th>
                            <th class="text-right p-3">Ingresos</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant">
                        @foreach (var p in Model.Properties)
                        {
                            <tr>
                                <td class="p-3 font-semibold text-on-background">@p.Title</td>
                                <td class="p-3 text-right">@p.Bookings</td>
                                <td class="p-3 text-right">@p.NightsBooked</td>
                                <td class="p-3 text-right">@p.OccupancyRate.ToString("P0")</td>
                                <td class="p-3 text-right font-bold text-primary">@p.Revenue.Cop()</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</main>
